00500113 // addi x2, x0, 5    (x2 = 5)
00a00193 // addi x3, x0, 10   (x3 = 10)
00310233 // add  x4, x2, x3   (x4 = 5 + 10 = 15)
402302b3 // sub  x5, x6, x2   (x5 = x6 - x2 = 0 - 5 = -5)
00412023 // sw   x4, 0(x2)    (DataMem[5] = 15)
00502303 // lw   x6, 0(x2)    (x6 = DataMem[5] = 15)
00430463 // beq  x6, x4, 8    (If x6 == x4, PC = PC + 8 -> Skip next instruction)
00500113 // addi x2, x0, 5    (Should be skipped if BEQ works)
00a10333 // add  x6, x2, x10  (Target of branch)
